{
	"name": "diva-react-client",
	"version": "1.0.0",
	"description": "A react client for DiVA.",
	"dependencies": {
		"@types/react-router": "^5.1.18",
		"axios": "^0.27.2",
		"diva-cora-ts-api-wrapper": "file:../diva-cora-ts-api-wrapper",
		"grommet": "^2.23.0",
		"grommet-icons": "^4.7.0",
		"react": "^18.1.0",
		"react-dom": "^18.1.0",
		"react-router": "^6.3.0",
		"react-router-dom": "^6.3.0",
		"styled-components": "^5.3.5"
	},
	"devDependencies": {
		"@babel/cli": "^7.17.10",
		"@babel/core": "^7.18.2",
		"@babel/plugin-proposal-class-properties": "^7.17.12",
		"@babel/preset-env": "^7.18.2",
		"@babel/preset-react": "^7.17.12",
		"@babel/preset-typescript": "^7.17.12",
		"@testing-library/jest-dom": "^5.16.4",
		"@testing-library/react": "^13.3.0",
		"@testing-library/user-event": "^14.2.0",
		"@types/jest": "^27.5.1",
		"@types/node": "^17.0.38",
		"@types/react": "^18.0.10",
		"@types/react-dom": "^18.0.5",
		"@types/styled-components": "^5.1.25",
		"@types/testing-library__jest-dom": "^5.14.3",
		"@typescript-eslint/eslint-plugin": "^5.27.0",
		"@typescript-eslint/parser": "^5.27.0",
		"diva-resource-fetcher": "file:../diva-resource-fetcher",
		"eslint": "^8.16.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-prettier": "^8.5.0",
		"eslint-import-resolver-typescript": "^2.7.1",
		"eslint-plugin-html": "^6.2.0",
		"eslint-plugin-import": "^2.26.0",
		"eslint-plugin-jsx-a11y": "^6.5.1",
		"eslint-plugin-prettier": "^4.0.0",
		"eslint-plugin-react": "^7.30.0",
		"eslint-plugin-react-hooks": "^4.5.0",
		"fs": "^0.0.1-security",
		"jest": "^28.1.0",
		"jest-environment-jsdom": "^28.1.0",
		"parcel": "^2.6.0",
		"prettier": "^2.6.2",
		"process": "^0.11.10",
		"ts-jest": "^28.0.3",
		"typescript": "^4.7.2",
		"whatwg-fetch": "^3.6.2"
	},
	"scripts": {
		"type-check": "tsc --noEmit",
		"type-check:watch": "npm run type-check -- --watch",
		"build": "npm run build:types && npm run build:js",
		"build:prod": "npm run build:types && parcel build ./src/index.html --dist-dir ./dist --public-url $BASENAME",
		"build:types": "tsc --emitDeclarationOnly",
		"build:js": "babel src --out-dir lib --extensions \".ts,.tsx\" --source-maps inline",
		"start": "parcel -p 3000 src/index.html",
		"eslint": "npx eslint \"src/**/*\" --quiet --fix/;exit 0",
		"test": "jest --watch",
		"test:file": "jest --watch --testPathPattern",
		"coverage": "npm run coverage:dev /; npm run coverage:show",
		"coverage:dev": "jest --coverage /;exit 0",
		"coverage:deploy": "jest --coverage",
		"coverage:show": "firefox ~/workspace/diva-react-client/diva-react-client/coverage/lcov-report/index.html",
		"fetch-diva-resources": "npx divaResourceFetcher ./lists/"
	},
	"author": "Library Systems Unit - Uppsala University Library",
	"license": "GPL-3.0"
}
